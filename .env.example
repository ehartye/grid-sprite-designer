# Required: Google Gemini API key for image generation
GEMINI_API_KEY=your-api-key-here

# Optional: Server port (default: 3002)
# PORT=3002

# Optional: Database file path (default: data/grid-sprite.db)
# DB_PATH=./data/grid-sprite.db

# Optional: Node environment (development | production)
# NODE_ENV=development

# Optional: Comma-separated CORS allowed origins (default: http://localhost:5173,http://localhost:5174)
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
